---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import { fetchCategories, fetchCourses } from '../../lib/api.js';
import { slugify } from '../../lib/utils.js';

const { slug } = Astro.params;

const [categories, allCourses] = await Promise.all([fetchCategories(), fetchCourses()]);

const category = categories.find((cat: any) => {
  const name = cat.attributes?.name ?? cat.name ?? '';
  return (cat.attributes?.slug ?? slugify(name)) === slug;
});

if (!category) {
  return Astro.redirect('/categorias');
}

const categoryId = category.id;
const categoryName = category.attributes?.name ?? category.name ?? 'Categoría';
const categoryDescription = category.attributes?.description ?? category.description ?? '';

const categoryCourses = allCourses.filter((course: any) => {
  const catId = course.attributes?.category?.data?.id ?? course.category?.id;
  return catId === categoryId;
});
---

<BaseLayout
  title={`${categoryName} | Learnify`}
  description={`Cursos de ${categoryName} en Learnify`}
>
  <main class="flex-1">
    <Section class="py-16 bg-gradient-to-br from-blue-600 to-blue-900 text-white">
      <Container>
        <a
          href="/categorias"
          class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-lg border border-white/50 text-white text-sm font-medium hover:bg-white/10 transition-colors no-underline"
        >
          ← Volver a Categorías
        </a>
        <h1 class="text-4xl font-bold mb-3">{categoryName}</h1>
        {categoryDescription && (
          <p class="text-xl opacity-90 max-w-2xl mb-3">{categoryDescription}</p>
        )}
        <p class="opacity-75 text-sm">
          {categoryCourses.length}
          {categoryCourses.length === 1 ? ' curso disponible' : ' cursos disponibles'}
        </p>
      </Container>
    </Section>

    <Section class="py-16">
      <Container>
        {categoryCourses.length === 0 ? (
          <div class="text-center py-16">
            <p class="text-text-muted text-lg mb-6">
              No hay cursos disponibles en esta categoría todavía.
            </p>
            <a
              href="/categorias"
              class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-medium rounded-lg hover:bg-blue-700 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 no-underline"
            >
              Ver todas las categorías
            </a>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {categoryCourses.map((course: any) => (
              <Card
                title={course.attributes?.title ?? course.title ?? 'Sin título'}
                description={course.attributes?.description ?? course.description}
                image={course.attributes?.image?.data?.attributes?.url}
                href={`/cursos/${course.attributes?.slug ?? course.slug}`}
              />
            ))}
          </div>
        )}
      </Container>
    </Section>
  </main>
</BaseLayout>
