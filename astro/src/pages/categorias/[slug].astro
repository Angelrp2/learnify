---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import { fetchCategories, fetchCourses } from '../../lib/api.js';
import { slugify } from '../../lib/utils.js';

export async function getStaticPaths() {
  const [categories, allCourses] = await Promise.all([fetchCategories(), fetchCourses()]);

  return categories.map((cat: any) => {
    const name = cat.attributes?.name ?? cat.name ?? '';
    const slug = cat.attributes?.slug ?? slugify(name);
    const courses = allCourses.filter(
      (c: any) => (c.attributes?.category?.data?.id ?? c.category?.id) === cat.id
    );
    return {
      params: { slug },
      props: { categoryName: name, courses },
    };
  });
}

const { categoryName, courses } = Astro.props;
---

<BaseLayout
  title={`${categoryName} | Learnify`}
  description={`Cursos de ${categoryName} en Learnify`}
>
  <main class="flex-1">
    <Section class="py-16">
      <Container>
        <nav class="text-sm text-text-muted mb-6">
          <a href="/categorias" class="text-primary hover:underline no-underline">Categorías</a>
          <span class="mx-2">/</span>
          <span>{categoryName}</span>
        </nav>

        <h1 class="text-3xl font-bold mb-2 text-text-base">{categoryName}</h1>
        <p class="text-text-muted mb-10">
          {courses.length}
          {courses.length === 1 ? 'curso disponible' : 'cursos disponibles'}
        </p>

        {
          courses.length === 0 ? (
            <div class="text-center py-16">
              <p class="text-text-muted text-lg mb-4">
                No hay cursos en esta categoría todavía.
              </p>
              <a href="/cursos" class="text-primary hover:underline no-underline">
                Ver todos los cursos →
              </a>
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {courses.map((course: any) => (
                <Card
                  title={course.attributes?.title ?? course.title ?? 'Sin título'}
                  description={course.attributes?.description ?? course.description}
                  image={course.attributes?.image?.data?.attributes?.url}
                  href={`/cursos/${course.attributes?.slug ?? course.slug}`}
                />
              ))}
            </div>
          )
        }
      </Container>
    </Section>
  </main>
</BaseLayout>
