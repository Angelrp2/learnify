---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchGitHubRepositories } from '../lib/github-api';

const repositories = await fetchGitHubRepositories('javascript-tutorial');

const title = 'Recursos | Learnify';
const description = 'Repositorios de GitHub con ejemplos de código y tutoriales';
---

<BaseLayout title={title} description={description}>
  <main>
    <div class="container">
      <h1>Recursos de Aprendizaje</h1>
      <p class="subtitle">Repositorios de GitHub con ejemplos de código y tutoriales</p>

      {repositories.length === 0 ? (
        <div class="no-resources">
          <p>No se pudieron cargar los recursos en este momento. Intenta más tarde.</p>
        </div>
      ) : (
        <div class="resources-grid">
          {repositories.map(repo => (
            <article class="resource-card">
              <div class="resource-header">
                <h2>
                  <a href={repo.html_url} target="_blank" rel="noopener noreferrer">
                    {repo.name}
                  </a>
                </h2>
                <span class="language">{repo.language || 'No especificado'}</span>
              </div>

              <p class="description">{repo.description || 'Sin descripción'}</p>

              <div class="resource-stats">
                <span class="stat">
                  <span class="label">Stars:</span> {repo.stargazers_count}
                </span>
                <span class="stat">
                  <span class="label">Forks:</span> {repo.forks_count}
                </span>
                <span class="stat">
                  <span class="label">Issues:</span> {repo.open_issues_count}
                </span>
              </div>

              <div class="resource-footer">
                <span class="owner">Por: {repo.owner.login}</span>
                <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="view-repo">
                  Ver en GitHub →
                </a>
              </div>
            </article>
          ))}
        </div>
      )}

      <div class="resources-info">
        <h2>Sobre estos Recursos</h2>
        <p>
          Los recursos mostrados se obtienen en tiempo real desde la API de GitHub. Se muestran los repositorios más populares etiquetados con "javascript-tutorial", ordenados por número de estrellas.
        </p>
        <p>
          Esta integración demuestra el consumo de una API externa pública que enriquece la experiencia del usuario proporcionando ejemplos reales de código.
        </p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  h1 {
    margin: 2rem 0 0.5rem;
    font-size: 2rem;
  }

  .subtitle {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  .no-resources {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-secondary);
    background-color: var(--bg-secondary);
    border-radius: 0.5rem;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
  }

  .resource-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .resource-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .resource-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .resource-card h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .resource-card h2 a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .resource-card h2 a:hover {
    color: #1e40af;
  }

  .language {
    display: inline-block;
    background-color: var(--color-primary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .description {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    flex: 1;
    line-height: 1.6;
  }

  .resource-stats {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }

  .stat {
    display: flex;
    gap: 0.5rem;
  }

  .stat .label {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .resource-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .owner {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .view-repo {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .view-repo:hover {
    color: #1e40af;
  }

  .resources-info {
    background-color: var(--bg-secondary);
    padding: 2rem;
    border-radius: 0.5rem;
    margin-top: 3rem;
    border: 1px solid var(--border);
  }

  .resources-info h2 {
    margin-top: 0;
  }

  .resources-info p {
    line-height: 1.8;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .resources-grid {
      grid-template-columns: 1fr;
    }

    .resource-header {
      flex-direction: column;
    }

    .language {
      align-self: flex-start;
    }
  }
</style>
