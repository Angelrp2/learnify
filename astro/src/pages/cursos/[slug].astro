---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { fetchCourses, fetchCourseBySlug } from '../../lib/api';

const { slug } = Astro.params;
const course = await fetchCourseBySlug(slug);

if (!course) {
  return Astro.redirect('/404');
}

const { attributes } = course;
const title = attributes.seo?.metaTitle || `${attributes.title} | Learnify`;
const description = attributes.seo?.metaDescription || attributes.description;
---

<BaseLayout title={title} description={description}>
  <main>
    <div class="container">
      <div class="breadcrumb">
        <a href="/cursos">Cursos</a>
        <span>/</span>
        <span>{attributes.title}</span>
      </div>

      <article class="course-detail">
        <header class="course-header">
          {attributes.image && (
            <img src={attributes.image} alt={attributes.title} class="course-image" />
          )}
          <div class="course-meta">
            <h1>{attributes.title}</h1>
            <div class="course-info">
              <span class="difficulty" data-level={attributes.difficulty}>
                {attributes.difficulty}
              </span>
              <span class="duration">
                {attributes.duration} minutos
              </span>
              {attributes.category?.data && (
                <span class="category">
                  {attributes.category.data.attributes.name}
                </span>
              )}
            </div>
            {attributes.instructor?.data && (
              <div class="instructor">
                <p>Por: {attributes.instructor.data.attributes.name}</p>
              </div>
            )}
          </div>
        </header>

        <div class="course-content">
          <section class="description">
            <h2>Descripción</h2>
            <p>{attributes.description}</p>
          </section>

          <section class="content">
            <h2>Contenido del Curso</h2>
            <div set:html={attributes.content}></div>
          </section>

          {attributes.lessons?.data && attributes.lessons.data.length > 0 && (
            <section class="lessons">
              <h2>Lecciones</h2>
              <ul class="lessons-list">
                {attributes.lessons.data.map((lesson, index) => (
                  <li>
                    <span class="lesson-number">{index + 1}</span>
                    <span class="lesson-title">{lesson.attributes.title}</span>
                    {lesson.attributes.duration && (
                      <span class="lesson-duration">{lesson.attributes.duration} min</span>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          )}

          <div class="course-actions">
            <Button href="/cursos">Volver a Cursos</Button>
          </div>
        </div>
      </article>
    </div>
  </main>
</BaseLayout>

<style>
  .breadcrumb {
    margin: 1rem 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb span {
    margin: 0 0.5rem;
  }

  .course-detail {
    margin: 2rem 0;
  }

  .course-header {
    background-color: var(--bg-secondary);
    padding: 2rem;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
  }

  .course-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .course-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .course-info {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .difficulty {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .difficulty[data-level="beginner"] {
    background-color: #d1fae5;
    color: #065f46;
  }

  .difficulty[data-level="intermediate"] {
    background-color: #fef3c7;
    color: #78350f;
  }

  .difficulty[data-level="advanced"] {
    background-color: #fee2e2;
    color: #7f1d1d;
  }

  .duration,
  .category {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  .instructor {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .instructor p {
    margin: 0;
    color: var(--text-secondary);
  }

  .course-content {
    max-width: 800px;
  }

  .course-content section {
    margin-bottom: 2rem;
  }

  .course-content h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .course-content p {
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .lessons-list {
    list-style: none;
    padding: 0;
  }

  .lessons-list li {
    display: flex;
    align-items: center;
    padding: 1rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    margin-bottom: 0.5rem;
    gap: 1rem;
  }

  .lesson-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background-color: var(--color-primary);
    color: white;
    border-radius: 50%;
    font-weight: bold;
    flex-shrink: 0;
  }

  .lesson-title {
    flex: 1;
  }

  .lesson-duration {
    font-size: 0.875rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .course-actions {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .course-header h1 {
      font-size: 1.75rem;
    }

    .course-info {
      flex-direction: column;
    }

    .difficulty,
    .duration,
    .category {
      display: block;
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  // Scroll suave
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
