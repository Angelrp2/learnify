---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import { fetchCourses, fetchCourseBySlug } from '../../lib/api';

const { slug } = Astro.params;
const course = await fetchCourseBySlug(slug);

if (!course) {
  return Astro.redirect('/404');
}

const { attributes } = course;
const title = attributes.seo?.metaTitle || `${attributes.title} | Learnify`;
const description = attributes.seo?.metaDescription || attributes.description;

const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://localhost:1337';

function getImageUrl(image: any): string | null {
  if (!image) return null;
  if (typeof image === 'string') {
    return image.startsWith('http') ? image : `${STRAPI_URL}${image}`;
  }
  if (typeof image === 'object' && image.data?.attributes?.url) {
    const url = image.data.attributes.url;
    return url.startsWith('http') ? url : `${STRAPI_URL}${url}`;
  }
  return null;
}

const imageUrl = getImageUrl(attributes.image?.data?.attributes?.url);

const difficultyColors = {
  beginner: { bg: 'bg-green-100', text: 'text-green-800', label: 'Principiante' },
  intermediate: { bg: 'bg-yellow-100', text: 'text-yellow-800', label: 'Intermedio' },
  advanced: { bg: 'bg-red-100', text: 'text-red-800', label: 'Avanzado' }
};

const difficulty = attributes.difficulty || 'beginner';
const difficultyStyle = difficultyColors[difficulty as keyof typeof difficultyColors] || difficultyColors.beginner;
---

<BaseLayout title={title} description={description}>
  <main class="flex-1">
    {/* Hero Section con imagen */}
    {imageUrl && (
      <div class="relative h-96 overflow-hidden bg-gradient-to-br from-blue-600 to-blue-900">
        <img 
          src={imageUrl} 
          alt={attributes.title} 
          class="w-full h-full object-cover opacity-60"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
      </div>
    )}

    <Section class="py-8 sm:py-12">
      <Container>
        {/* Breadcrumb */}
        <nav class="flex items-center gap-2 text-sm text-text-muted mb-6 sm:mb-8">
          <a href="/cursos" class="text-primary hover:text-blue-700 transition-colors no-underline">Cursos</a>
          <span>/</span>
          <span class="text-text-base">{attributes.title}</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {/* Contenido principal */}
          <div class="lg:col-span-2">
            {/* Título y meta */}
            <div class="mb-8">
              <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-text-base mb-4 leading-tight">
                {attributes.title}
              </h1>
              
              <div class="flex flex-wrap items-center gap-3 mb-6">
                <span class={`inline-block px-4 py-2 rounded-lg font-medium text-sm ${difficultyStyle.bg} ${difficultyStyle.text}`}>
                  {difficultyStyle.label}
                </span>
                
                {attributes.duration && (
                  <span class="inline-flex items-center gap-2 px-4 py-2 bg-bg-muted rounded-lg text-text-base">
                    <span>⏱️</span>
                    <span>{attributes.duration} minutos</span>
                  </span>
                )}
                
                {attributes.category?.data && (
                  <span class="inline-flex items-center gap-2 px-4 py-2 bg-bg-muted rounded-lg text-text-base">
                    <span>📁</span>
                    <span>{attributes.category.data.attributes.name}</span>
                  </span>
                )}
              </div>

              {attributes.instructor?.data && (
                <div class="flex items-center gap-3 text-text-muted mb-6">
                  <span class="text-2xl">👨‍🏫</span>
                  <div>
                    <p class="text-sm text-text-muted">Instructor</p>
                    <p class="text-lg font-medium text-text-base">{attributes.instructor.data.attributes.name}</p>
                  </div>
                </div>
              )}
            </div>

            {/* Descripción */}
            <section class="mb-12">
              <h2 class="text-2xl font-bold text-text-base mb-4">Descripción</h2>
              <p class="text-text-muted leading-relaxed text-lg">
                {attributes.description}
              </p>
            </section>

            {/* Contenido del curso */}
            {attributes.content && (
              <section class="mb-12">
                <h2 class="text-2xl font-bold text-text-base mb-4">Contenido del Curso</h2>
                <div class="prose prose-invert max-w-none text-text-muted">
                  <div set:html={attributes.content}></div>
                </div>
              </section>
            )}

            {/* Lecciones */}
            {attributes.lessons?.data && attributes.lessons.data.length > 0 && (
              <section class="mb-12">
                <h2 class="text-2xl font-bold text-text-base mb-6">Lecciones del Curso</h2>
                <div class="space-y-3">
                  {attributes.lessons.data.map((lesson, index) => (
                    <div class="flex items-start gap-4 p-4 bg-bg-muted rounded-lg border border-border hover:border-primary transition-colors">
                      <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 bg-primary text-white rounded-full font-bold text-sm">
                        {index + 1}
                      </div>
                      <div class="flex-1 min-w-0">
                        <h3 class="text-lg font-semibold text-text-base">
                          {lesson.attributes.title}
                        </h3>
                        {lesson.attributes.description && (
                          <p class="text-sm text-text-muted mt-1">
                            {lesson.attributes.description}
                          </p>
                        )}
                      </div>
                      {lesson.attributes.duration && (
                        <div class="flex-shrink-0 text-sm text-text-muted whitespace-nowrap">
                          {lesson.attributes.duration} min
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            )}

            {/* Botón de volver */}
            <div class="pt-8 border-t border-border">
              <Button href="/cursos" class="inline-block">← Volver a Cursos</Button>
            </div>
          </div>

          {/* Sidebar */}
          <aside class="lg:col-span-1">
            <div class="sticky top-24 bg-bg-muted rounded-lg border border-border p-6">
              <h3 class="text-xl font-bold text-text-base mb-6">Información del Curso</h3>
              
              <div class="space-y-6">
                <div>
                  <p class="text-sm text-text-muted mb-2">Nivel de Dificultad</p>
                  <span class={`inline-block px-4 py-2 rounded-lg font-medium text-sm ${difficultyStyle.bg} ${difficultyStyle.text}`}>
                    {difficultyStyle.label}
                  </span>
                </div>

                {attributes.duration && (
                  <div>
                    <p class="text-sm text-text-muted mb-2">Duración Total</p>
                    <p class="text-lg font-semibold text-text-base">{attributes.duration} minutos</p>
                  </div>
                )}

                {attributes.category?.data && (
                  <div>
                    <p class="text-sm text-text-muted mb-2">Categoría</p>
                    <p class="text-lg font-semibold text-text-base">{attributes.category.data.attributes.name}</p>
                  </div>
                )}

                {attributes.instructor?.data && (
                  <div>
                    <p class="text-sm text-text-muted mb-2">Instructor</p>
                    <p class="text-lg font-semibold text-text-base">{attributes.instructor.data.attributes.name}</p>
                  </div>
                )}

                {attributes.lessons?.data && (
                  <div>
                    <p class="text-sm text-text-muted mb-2">Número de Lecciones</p>
                    <p class="text-lg font-semibold text-text-base">{attributes.lessons.data.length} lecciones</p>
                  </div>
                )}

                <Button href="/contacto" class="w-full text-center block">Contactar</Button>
              </div>
            </div>
          </aside>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>
