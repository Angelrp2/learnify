---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Cursos | Learnify';
const description = 'Explora nuestro catálogo completo de cursos de programación';
---

<BaseLayout title={title} description={description}>
  <main>
    <div class="container">
      <h1>Cursos Disponibles</h1>
      
      <div class="courses-section">
        <aside class="sidebar">
          <div class="filter-group">
            <h3>Filtros</h3>
            <div class="filter-item">
              <label>
                <input type="checkbox" name="difficulty" value="beginner" />
                Principiante
              </label>
            </div>
            <div class="filter-item">
              <label>
                <input type="checkbox" name="difficulty" value="intermediate" />
                Intermedio
              </label>
            </div>
            <div class="filter-item">
              <label>
                <input type="checkbox" name="difficulty" value="advanced" />
                Avanzado
              </label>
            </div>
          </div>
        </aside>

        <div class="main-content">
          <div class="search-bar">
            <input type="text" placeholder="Buscar cursos..." />
          </div>

          <div class="courses-grid">
            <p>Cargando cursos...</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  h1 {
    margin: 2rem 0 1rem;
    font-size: 2rem;
  }

  .courses-section {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 2rem;
    margin: 2rem 0;
  }

  .sidebar {
    background-color: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: 0.5rem;
    height: fit-content;
  }

  .filter-group h3 {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .filter-item {
    margin-bottom: 0.75rem;
  }

  .filter-item label {
    display: flex;
    align-items: center;
    cursor: pointer;
    gap: 0.5rem;
  }

  .search-bar {
    margin-bottom: 2rem;
  }

  .search-bar input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-size: 1rem;
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .courses-section {
      grid-template-columns: 1fr;
    }

    .sidebar {
      order: 2;
    }

    .main-content {
      order: 1;
    }
  }
</style>
