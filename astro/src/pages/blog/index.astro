---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import { fetchBlogPosts } from '../../lib/api';
import { calculateReadingTime } from '../../lib/utils';

const posts = await fetchBlogPosts();
const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://localhost:1337';

const title = 'Blog | Learnify';
const description = 'Artículos educativos sobre programación y desarrollo web';

function getImageUrl(image: any): string | null {
  if (!image) return null;
  if (typeof image === 'string') {
    return image.startsWith('http') ? image : `${STRAPI_URL}${image}`;
  }
  if (typeof image === 'object' && image.data?.attributes?.url) {
    const url = image.data.attributes.url;
    return url.startsWith('http') ? url : `${STRAPI_URL}${url}`;
  }
  return null;
}
---

<BaseLayout title={title} description={description}>
  <main class="flex-1">
    <Section class="py-12">
      <Container>
        <div class="mb-12">
          <h1 class="text-4xl font-bold text-text-base mb-3">Blog</h1>
          <p class="text-lg text-text-muted">Artículos educativos sobre programación y desarrollo web</p>
        </div>

        {posts.length === 0 ? (
          <div class="py-16 text-center">
            <p class="text-text-muted text-lg">No hay artículos disponibles</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map(post => {
              const { attributes } = post;
              const readingTime = calculateReadingTime(attributes.content);
              const imageUrl = getImageUrl(attributes.image?.data?.attributes?.url);
              
              return (
                <article class="group bg-bg-muted rounded-lg overflow-hidden border border-border transition-all duration-300 hover:-translate-y-1 hover:shadow-lg flex flex-col">
                  {imageUrl && (
                    <div class="relative h-44 sm:h-48 overflow-hidden bg-bg-muted">
                      <img
                        src={imageUrl}
                        alt={attributes.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                  )}

                  <div class="p-4 sm:p-6 flex flex-col flex-1">
                    <div class="flex items-center gap-2 mb-3 flex-wrap">
                      {attributes.category?.data && (
                        <span class="inline-block px-3 py-1 bg-primary text-white text-xs font-medium rounded">
                          {attributes.category.data.attributes.name}
                        </span>
                      )}
                      <span class="text-xs text-text-muted">{readingTime} min de lectura</span>
                    </div>
                    
                    <h2 class="text-xl font-semibold text-text-base mb-2 line-clamp-2">
                      <a href={`/blog/${attributes.slug}`} class="hover:text-primary transition-colors no-underline">
                        {attributes.title}
                      </a>
                    </h2>
                    
                    <p class="text-text-muted text-sm mb-4 line-clamp-3 flex-1">
                      {attributes.excerpt || attributes.description}
                    </p>
                    
                    <div class="flex items-center justify-between pt-4 border-t border-border">
                      <div class="flex items-center gap-2 text-xs text-text-muted">
                        {attributes.author?.data && (
                          <span>Por {attributes.author.data.attributes.name}</span>
                        )}
                        {attributes.publishedAt && (
                          <span>
                            {new Date(attributes.publishedAt).toLocaleDateString('es-ES', {
                              year: 'numeric',
                              month: 'short',
                              day: 'numeric'
                            })}
                          </span>
                        )}
                      </div>
                      <a 
                        href={`/blog/${attributes.slug}`} 
                        class="text-primary font-medium text-sm hover:text-blue-700 transition-colors no-underline"
                      >
                        Leer →
                      </a>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </Container>
    </Section>
  </main>
</BaseLayout>
