---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import { fetchBlogPosts } from '../../lib/api';
import { calculateReadingTime } from '../../lib/utils';

const STRAPI_URL = (import.meta.env.STRAPI_URL || 'http://127.0.0.1:1337').trim();

function getImageUrl(image: any): string | null {
  if (!image) return null;
  if (typeof image === 'string') return image.startsWith('http') ? image : `${STRAPI_URL}${image}`;
  if (image?.data?.attributes?.url) {
    const url = image.data.attributes.url;
    return url.startsWith('http') ? url : `${STRAPI_URL}${url}`;
  }
  return null;
}

const { slug } = Astro.params;
const posts = await fetchBlogPosts();
const post = posts.find((p: any) => p.attributes.slug === slug);

if (!post) return Astro.redirect('/404');

const { attributes } = post;
const title = attributes.seoTitle || `${attributes.title} | Learnify`;
const description = attributes.seoDescription || attributes.excerpt;
const readingTime = calculateReadingTime(attributes.content);
const imageUrl = getImageUrl(attributes.image);
---

<BaseLayout title={title} description={description}>
  <main class="flex-1">
    {imageUrl && (
      <div class="w-full h-48 sm:h-64 md:h-80 overflow-hidden bg-bg-muted">
        <img src={imageUrl} alt={attributes.title} class="w-full h-full object-cover" />
      </div>
    )}

    <Section class="py-8 sm:py-12">
      <Container size="md">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-1.5 text-xs sm:text-sm text-text-muted mb-6 sm:mb-8 flex-wrap">
          <a href="/blog" class="text-primary hover:text-blue-700 transition-colors no-underline">Blog</a>
          <span>/</span>
          <span class="truncate max-w-[200px] sm:max-w-none">{attributes.title}</span>
        </nav>

        <article>
          <!-- Header -->
          <header class="mb-6 sm:mb-10">
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-text-base mb-4 leading-tight">
              {attributes.title}
            </h1>

            <div class="flex flex-wrap items-center gap-2 sm:gap-3 mb-4">
              {attributes.category?.data && (
                <span class="inline-block px-2.5 sm:px-3 py-1 bg-primary text-white text-xs sm:text-sm font-medium rounded">
                  {attributes.category.data.attributes.name}
                </span>
              )}
              <span class="text-xs sm:text-sm text-text-muted">{readingTime} min de lectura</span>
              {attributes.publishedAt && (
                <span class="text-xs sm:text-sm text-text-muted">
                  {new Date(attributes.publishedAt).toLocaleDateString('es-ES', {
                    year: 'numeric', month: 'long', day: 'numeric'
                  })}
                </span>
              )}
            </div>

            {attributes.author?.data && (
              <div class="flex items-center gap-2 pt-4 border-t border-border">
                <span class="text-sm text-text-muted">
                  Por <strong class="text-text-base">{attributes.author.data.attributes.name}</strong>
                </span>
              </div>
            )}
          </header>

          <!-- Content -->
          <div class="prose-content text-text-base leading-relaxed" set:html={attributes.content} />

          <!-- Footer -->
          <footer class="mt-8 sm:mt-12 pt-6 sm:pt-8 border-t border-border">
            <Button href="/blog" variant="outline">← Volver al Blog</Button>
          </footer>
        </article>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .prose-content {
    font-size: clamp(0.95rem, 2.5vw, 1.05rem);
    line-height: 1.8;
  }
  .prose-content :global(h2) {
    font-size: clamp(1.2rem, 4vw, 1.75rem);
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: var(--text-base);
  }
  .prose-content :global(h3) {
    font-size: clamp(1rem, 3vw, 1.25rem);
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: var(--text-base);
  }
  .prose-content :global(p) {
    margin-bottom: 1rem;
    color: var(--text-muted);
  }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: var(--text-muted);
  }
  .prose-content :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose-content :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1rem;
    margin: 1.25rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .prose-content :global(code) {
    background-color: var(--bg-muted);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Courier New', monospace;
    font-size: 0.875em;
    color: var(--text-base);
  }
  .prose-content :global(pre) {
    background-color: var(--bg-muted);
    border: 1px solid var(--border);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.25rem 0;
  }
  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }
  .prose-content :global(a) {
    color: var(--primary);
    text-decoration: underline;
  }
  .prose-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1rem 0;
  }
</style>
