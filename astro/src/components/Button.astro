---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  class?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  disabled = false,
  class: className = '',
} = Astro.props;

const variantClasses: Record<string, string> = {
  primary: 'bg-primary text-white hover:bg-blue-700 hover:shadow-lg',
  secondary: 'bg-secondary text-white hover:bg-slate-500',
  outline: 'bg-transparent text-primary border-2 border-primary hover:bg-primary hover:text-white',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const base =
  'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 no-underline text-center hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none';

const classes = [base, variantClasses[variant], sizeClasses[size], className].join(' ');
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} disabled={disabled} class={classes}>
      <slot />
    </button>
  )
}
